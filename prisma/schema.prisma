generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts         Account[]
  sessions         Session[]
  enrollments      Enrollment[]
  waitlistEntries  WaitlistEntry[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Bootcamp {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String
  priceNGN    Int
  priceUSD    Int
  curriculum  String       // JSON string for simplicity in SQLite 
  isActive         Boolean          @default(true)
  startDate        DateTime         @default(now()) // Added for conditional join logic
  duration         String           @default("6 Weeks")
  enrollments      Enrollment[]
  waitlistEntries  WaitlistEntry[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Enrollment {
  id             String        @id @default(cuid())
  userId         String
  bootcampId     String
  transactionId  String?       @unique // Stripe payment_intent or Flutterwave transaction_id
  discountCodeId String?       // Track which discount code was used
  status         String        @default("enrolled") // enrolled, completed, dropped
  enrolledAt     DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bootcamp       Bootcamp      @relation(fields: [bootcampId], references: [id], onDelete: Cascade)
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])

  @@unique([userId, bootcampId])
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  userId     String
  bootcampId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bootcamp   Bootcamp @relation(fields: [bootcampId], references: [id], onDelete: Cascade)

  @@unique([userId, bootcampId])
}

model DiscountCode {
  id                     String       @id @default(cuid())
  code                   String       @unique
  discountPercent        Int          // e.g. 20 for 20%
  description            String?      // e.g. "Alumni 20% discount"
  isActive               Boolean      @default(true)
  validFrom              DateTime     @default(now())
  validUntil             DateTime?
  maxUses                Int?         // null = unlimited
  currentUses            Int          @default(0)
  restrictedToBootcampId String?      // If set, only users enrolled in this bootcamp can use this code
  enrollments            Enrollment[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model PaymentLog {
  id            String   @id @default(cuid())
  transactionId String?
  userId        String?
  userEmail     String?
  bootcampId    String?
  source        String   // "verify" or "webhook"
  status        String   // "success", "failed", "error"
  errorMessage  String?
  amount        Float?
  currency      String?
  rawResponse   String?  // JSON stringified response from Flutterwave
  createdAt     DateTime @default(now())

  @@index([transactionId])
  @@index([userEmail])
  @@index([createdAt])
}

